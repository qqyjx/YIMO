%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#4f46e5', 'secondaryColor': '#818cf8', 'tertiaryColor': '#c7d2fe'}}}%%
flowchart TB
    subgraph Phase1["阶段一：数据采集与预处理"]
        A1[("DATA目录<br/>Excel文件")] --> A2["读取三层架构数据"]
        A2 --> A3["DA-01 概念实体清单<br/>(373个唯一实体)"]
        A2 --> A4["DA-02 逻辑实体清单<br/>(6101个唯一实体)"]
        A2 --> A5["DA-03 物理实体清单<br/>(待补充)"]
        A3 --> A6["收集所有唯一实体名称"]
        A4 --> A6
        A5 --> A6
        A6 --> A7["数据清洗<br/>去重、去噪"]
    end

    subgraph Phase2["阶段二：SBERT语义向量化"]
        A7 --> B1["加载SBERT模型<br/>(text2vec-base-chinese)"]
        B1 --> B2["实体名称向量化<br/>(768维向量)"]
        B2 --> B3["语义向量矩阵<br/>(N x 768)"]
    end

    subgraph Phase3["阶段三：层次聚类"]
        B3 --> C1["AgglomerativeClustering<br/>(余弦距离)"]
        C1 --> C2{"设定聚类数<br/>~15个"}
        C2 --> C3["语义聚类结果"]
        C3 --> C4["计算聚类中心"]
        C4 --> C5["采样代表性实体<br/>(每聚类20个)"]
    end

    subgraph Phase4["阶段四：大模型归纳命名"]
        C5 --> D1["构造归纳提示词"]
        D1 --> D2{"调用大模型<br/>(DeepSeek)"}
        D2 --> D3["为每个聚类<br/>归纳抽象对象名"]
        D3 --> D4["输出核心对象<br/>项目、设备、资产..."]
        D4 --> D5["确保必须对象存在<br/>(项目)"]
    end

    subgraph Phase5["阶段五：关联关系构建"]
        D5 --> E1["基于聚类成员关系<br/>构建对象-实体关联"]
        E1 --> E2["对象-概念实体<br/>关联"]
        E1 --> E3["对象-逻辑实体<br/>关联"]
        E1 --> E4["对象-物理实体<br/>关联"]
        E2 --> E5["计算关联强度<br/>(0.7-0.9)"]
        E3 --> E5
        E4 --> E5
        E5 --> E6["三层关联关系表"]
    end

    subgraph Phase6["阶段六：验证与入库"]
        E6 --> F1{"人工审核<br/>核心对象确认"}
        F1 -->|"通过"| F2["写入MySQL<br/>extracted_objects表"]
        F1 -->|"调整"| C2
        F2 --> F3["写入MySQL<br/>object_entity_relations表"]
        F3 --> F4["生成关联统计报告"]
    end

    subgraph Phase7["阶段七：前端可视化"]
        F4 --> G1["对象卡片视图"]
        G1 --> G2["三层关联图谱"]
        G2 --> G3["桑基图展示<br/>对象 -> 概念 -> 逻辑 -> 物理"]
        G3 --> G4["关联详情下钻"]
    end

    %% 算法核心亮点
    subgraph Legend["算法特点：自下而上的归纳抽取"]
        direction LR
        L1["传统方法：预定义关键词 -> 匹配分类"]
        L2["新方法：语义聚类 -> LLM归纳命名"]
        L1 -.->|"改进"| L2
    end

    style Phase1 fill:#e0f2fe,stroke:#0284c7
    style Phase2 fill:#fef3c7,stroke:#d97706
    style Phase3 fill:#fce7f3,stroke:#db2777
    style Phase4 fill:#d1fae5,stroke:#059669
    style Phase5 fill:#ede9fe,stroke:#7c3aed
    style Phase6 fill:#fee2e2,stroke:#dc2626
    style Phase7 fill:#f0fdf4,stroke:#22c55e
    style Legend fill:#f5f5f5,stroke:#666
