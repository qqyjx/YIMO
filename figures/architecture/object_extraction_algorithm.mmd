%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#4f46e5', 'secondaryColor': '#818cf8', 'tertiaryColor': '#c7d2fe'}}}%%
flowchart TB
    %% ============================================================
    %% 对象抽取与三层架构关联 - 完整算法流程图
    %% Object Extraction & Three-Tier Architecture Association
    %% 版本: v2.2.0
    %% ============================================================

    subgraph INPUT["数据源层"]
        direction TB
        I1[("DATA/2.xlsx<br/>输配电域<br/>数据架构")]
        I2[("计划财务域<br/>数据架构")]
        I3[("其他业务域<br/>数据架构")]
        I1 & I2 & I3 --> I4["多源数据汇聚"]
    end

    subgraph PHASE1["阶段一：三层架构数据采集"]
        direction TB
        P1A["📄 读取 DA-01<br/>概念实体清单<br/>(业务场景层)"]
        P1B["📄 读取 DA-02<br/>逻辑实体清单<br/>(交互表单层)"]
        P1C["📄 读取 DA-03<br/>物理实体清单<br/>(数据库层)"]

        P1A --> P1D["EntityInfo<br/>layer=CONCEPT"]
        P1B --> P1E["EntityInfo<br/>layer=LOGICAL"]
        P1C --> P1F["EntityInfo<br/>layer=PHYSICAL"]

        P1D & P1E & P1F --> P1G["合并去重<br/>保留来源元数据<br/>(data_domain, source_file)"]

        P1G --> P1H["输出: List&lt;EntityInfo&gt;<br/>~6500个唯一实体"]
    end

    subgraph PHASE2["阶段二：SBERT语义向量化"]
        direction TB
        P2A["加载SBERT模型<br/>shibing624/text2vec-base-chinese<br/>(768维中文语义向量)"]
        P2B["提取唯一实体名称"]
        P2C["批量向量化编码<br/>batch_size=64<br/>show_progress=True"]
        P2D["输出: embeddings<br/>numpy.ndarray[N, 768]"]

        P2A --> P2C
        P2B --> P2C
        P2C --> P2D
    end

    subgraph PHASE3["阶段三：层次聚类算法"]
        direction TB
        P3A["AgglomerativeClustering<br/>层次聚类"]
        P3B["参数配置:<br/>n_clusters = min(15, N//10)<br/>metric = cosine<br/>linkage = average"]
        P3C["执行聚类<br/>labels = fit_predict(embeddings)"]

        P3A --> P3C
        P3B --> P3C

        P3C --> P3D["构建聚类结果"]
        P3D --> P3E["计算聚类中心向量<br/>centroid = mean(cluster_emb)"]
        P3E --> P3F["选择中心代表实体<br/>argmax(cosine_similarity)"]
        P3F --> P3G["采样代表性实体<br/>top-20 by similarity<br/>(用于LLM归纳)"]

        P3G --> P3H["输出: ~15个语义聚类<br/>每个聚类含样本实体列表"]
    end

    subgraph PHASE4["阶段四：大模型归纳命名"]
        direction TB
        P4A{"LLM API可用?"}

        P4A -->|Yes| P4B["构建归纳Prompt"]
        P4B --> P4B1["包含聚类样本实体<br/>要求输出高度抽象对象名<br/>必须包含'项目'对象"]
        P4B1 --> P4C["调用 DeepSeek/GPT API<br/>temperature=0.3<br/>max_tokens=4000"]
        P4C --> P4D["解析JSON响应:<br/>object_code, object_name,<br/>object_type, synonyms,<br/>confidence, reasoning"]

        P4A -->|No| P4E["规则命名备选方案"]
        P4E --> P4F["关键词-对象映射表:<br/>项目/工程 → OBJ_PROJECT<br/>设备/变压器 → OBJ_DEVICE<br/>资产/固定 → OBJ_ASSET"]
        P4F --> P4G["投票统计<br/>选择最高频关键词对应对象"]

        P4D --> P4H["ExtractedObject列表"]
        P4G --> P4H

        P4H --> P4I{"包含必须对象?<br/>(项目等甲方要求)"}
        P4I -->|No| P4J["补充必须对象<br/>关联到最相关聚类"]
        P4J --> P4K["最终对象列表"]
        P4I -->|Yes| P4K

        P4K --> P4L["输出: ~15个核心对象<br/>项目、设备、资产、合同..."]
    end

    subgraph PHASE5["阶段五：三层架构关联构建"]
        direction TB
        P5A["遍历每个对象"]
        P5B["获取对应聚类的所有实体"]
        P5C["按entity_layer分组:<br/>CONCEPT / LOGICAL / PHYSICAL"]

        P5A --> P5B --> P5C

        P5C --> P5D["计算关联强度"]
        P5D --> P5D1["样本实体: strength=0.9"]
        P5D --> P5D2["其他实体: strength=0.7"]

        P5D1 & P5D2 --> P5E["创建EntityRelation:<br/>object_code, entity_layer,<br/>entity_name, relation_strength,<br/>match_method=SEMANTIC_CLUSTER"]

        P5E --> P5F["概念实体关联<br/>(业务场景)"]
        P5E --> P5G["逻辑实体关联<br/>(交互表单)"]
        P5E --> P5H["物理实体关联<br/>(数据库表)"]

        P5F & P5G & P5H --> P5I["输出: List&lt;EntityRelation&gt;<br/>~数千条关联关系"]
    end

    subgraph PHASE6["阶段六：数据持久化"]
        direction TB
        P6A["创建抽取批次记录<br/>object_extraction_batches"]
        P6B["写入对象表<br/>extracted_objects<br/>(UPSERT模式)"]
        P6C["写入同义词表<br/>object_synonyms"]
        P6D["写入关联关系表<br/>object_entity_relations"]
        P6E["更新批次统计"]
        P6F["生成统计报告"]

        P6A --> P6B --> P6C --> P6D --> P6E --> P6F
    end

    subgraph OUTPUT["输出与可视化"]
        direction TB
        O1["📊 统计卡片<br/>对象数 | 概念数 | 逻辑数 | 物理数"]
        O2["🎴 对象卡片网格<br/>点击查看详情"]
        O3["📋 三层关联面板<br/>概念/逻辑/物理实体标签"]
        O4["📁 JSON导出<br/>完整抽取结果"]
    end

    %% 连接各阶段
    INPUT --> PHASE1
    PHASE1 --> PHASE2
    P1H --> P2B
    PHASE2 --> PHASE3
    P2D --> P3A
    PHASE3 --> PHASE4
    P3H --> P4B
    P3H --> P4E
    PHASE4 --> PHASE5
    P4L --> P5A
    PHASE5 --> PHASE6
    P5I --> P6D
    PHASE6 --> OUTPUT

    %% 算法特点说明
    subgraph LEGEND["算法特点：自下而上的归纳抽取"]
        direction LR
        L1["❌ 旧方法: 预定义关键词 → 匹配分类"]
        L2["✅ 新方法: 语义聚类 → LLM归纳命名"]
        L1 -.->|"改进"| L2
    end

    %% 样式定义
    style INPUT fill:#f0f9ff,stroke:#0284c7,stroke-width:2px
    style PHASE1 fill:#fef3c7,stroke:#d97706,stroke-width:2px
    style PHASE2 fill:#fce7f3,stroke:#db2777,stroke-width:2px
    style PHASE3 fill:#d1fae5,stroke:#059669,stroke-width:2px
    style PHASE4 fill:#ede9fe,stroke:#7c3aed,stroke-width:2px
    style PHASE5 fill:#fee2e2,stroke:#dc2626,stroke-width:2px
    style PHASE6 fill:#e0e7ff,stroke:#4f46e5,stroke-width:2px
    style OUTPUT fill:#f0fdf4,stroke:#16a34a,stroke-width:2px
    style LEGEND fill:#f5f5f5,stroke:#666,stroke-width:1px
