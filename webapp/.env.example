# YIMO 网页应用配置示例
# 复制此文件为 .env 并填入实际值

# MySQL 数据库配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=eav_db
MYSQL_USER=eav_user
MYSQL_PASSWORD=eavpass123
TABLE_PREFIX=eav

# Embedding 模型配置
EMBED_MODEL=shibing624/text2vec-base-chinese
MODEL_CACHE=./models

# DeepSeek API 配置（可选，用于AI对话功能）
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your_api_key_here

# RAG 配置
RAG_TOP_K=5
