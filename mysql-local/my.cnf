[mysqld]
basedir=/usr
# 使用用户态数据目录
# 注意: datadir 需可写

datadir=/data1/xyf/smartgrid/mysql-local/dbdata
port=3307
socket=/data1/xyf/smartgrid/mysql-local/mysql.sock
pid-file=/data1/xyf/smartgrid/mysql-local/mysql.pid

# 仅监听本地，便于SSH隧道
bind-address=127.0.0.1

# 兼容性设置
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci

skip-networking=0

# 较小内存占用
innodb_buffer_pool_size=256M
innodb_log_file_size=64M

# 便于旧索引长度
innodb_file_format=Barracuda
innodb_file_per_table=1
innodb_default_row_format=DYNAMIC

# 日志
log-error=/data1/xyf/smartgrid/mysql-local/mysqld.log

[client]
socket=/data1/xyf/smartgrid/mysql-local/mysql.sock
port=3307
